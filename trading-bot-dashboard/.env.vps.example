# Same-origin API: nginx (or Vite dev) proxies /api → FastAPI on 127.0.0.1:6000
VITE_API_BASE_URL=/api
#
# Vite loads env by mode:
#   npm run build     → uses .env.production  →  cp .env.vps.example .env.production
#   npm run dev       → uses .env.development →  cp .env.vps.example .env.development
#   (If you skip both, dev still works: code falls back to baseURL `/api` + vite proxy.)
#
# Full URL instead of relative (only if API is on another host; no trailing slash on domain):
# VITE_API_BASE_URL=https://your-domain.com/api
