# Copy to .env.production before `npm run build` (or edit .env.production in repo).
#
# Prefer same-origin /api (nginx → 127.0.0.1:8000). Set full URL only if you expose :8000 without nginx.
#   VITE_API_BASE_URL=/api
# With HTTPS + domain later:
#   VITE_API_BASE_URL=https://api.yourdomain.com

VITE_API_BASE_URL=/api
