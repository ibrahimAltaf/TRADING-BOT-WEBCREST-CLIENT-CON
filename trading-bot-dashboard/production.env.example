# Copy to .env.production before `npm run build` (or edit .env.production in repo).
#
# CORS is configured on the FastAPI backend (allow_origins), not in this file.
#
# Current VPS API example:
#   VITE_API_BASE_URL=http://147.93.96.42:8000
# With HTTPS + domain later:
#   VITE_API_BASE_URL=https://api.yourdomain.com

VITE_API_BASE_URL=http://147.93.96.42:8000
