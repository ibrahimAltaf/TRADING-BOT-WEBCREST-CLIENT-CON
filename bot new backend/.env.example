APP_ENV=dev
# Production: set to production; use strong secrets and PostgreSQL on the VPS.
# APP_ENV=production

# Optional release label (shown in /status/summary when APP_VERSION set)
# APP_VERSION=1.0.0

DATABASE_URL=POSTGRE_URL

# Auth (login / exchange config modal)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

BINANCE_TESTNET=true
BINANCE_API_KEY=API_KEY
BINANCE_API_SECRET=API_SECRET
DATA_DIR=./data
LOG_LEVEL=INFO
BINANCE_SPOT_TESTNET_URL=TESTNET_API_URL
BINANCE_SPOT_MAINNET_URL=MAINNET_API_URL
BINANCE_SPOT_FALLBACK_URLS=

# === Machine Learning (Optional) ===
ML_ENABLED=false
ML_MODEL_DIR=models/lstm_v1
ML_LOOKBACK=100
ML_AGREE_THRESHOLD=0.70
ML_OVERRIDE_THRESHOLD=0.85

# ================================
# ADAPTIVE TRADING STRATEGY CONFIG
# ================================

# === General Trading Parameters ===
TRADE_SYMBOL=BTCUSDT
TRADE_TIMEFRAME=5m
TRADE_LOOKBACK=500

# === Regime Detection Parameters ===
# ADX >= 25 = Trending, ADX < 25 = Ranging
ADX_THRESHOLD=25.0
ATR_VOL_THRESHOLD=2.0

# === Trending Market Rules ===
EMA_FAST=20
EMA_SLOW=50
RSI_LEN=14
RSI_BUY_MIN=45.0
RSI_BUY_MAX=70.0
RSI_TAKE_PROFIT=75.0

# === Ranging Market Rules ===
BB_LEN=20
BB_STD=2.0
RSI_RANGE_BUY=35.0
RSI_RANGE_SELL=65.0

# === Risk Management ===
MAX_RISK_PER_TRADE=0.01
STOP_LOSS_ATR_MULT=2.0
TAKE_PROFIT_RR=2.0
MAX_OPEN_TRADES=1
COOLDOWN_SECONDS=60

# === Order Execution Mode ===
DEMO_OPEN_ONLY=false
DEMO_FILL_MODE=true

# === Scheduler (live auto-trade) ===
LIVE_SCHEDULER_ENABLED=false
# Interval in minutes; increase to 10–15 if jobs often run long (avoids "previous run still in progress")
SCHEDULER_INTERVAL_MINUTES=5

# === Testing only: relax entry to get more BUY/SELL signals (use on testnet only) ===
RELAXED_ENTRY_FOR_TESTING=false

# === VPS / production dashboard (CORS + startup-check) ===
# Comma-separated browser origins allowed to call the API (your dashboard URL(s)).
# Example: CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# CORS_ORIGINS=

# Optional: full URL of deployed dashboard — used by GET /status/startup-check to ping UI
# DASHBOARD_URL=https://app.yourdomain.com
