APP_ENV=dev
# Production: set to production; use strong secrets and PostgreSQL on the VPS.
# APP_ENV=production

# Optional release label (shown in /status/summary when APP_VERSION set)
# APP_VERSION=1.0.0

DATABASE_URL=POSTGRE_URL

# Auth (login / exchange config modal)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

BINANCE_TESTNET=true
BINANCE_API_KEY=API_KEY
BINANCE_API_SECRET=API_SECRET
DATA_DIR=./data
LOG_LEVEL=INFO
BINANCE_SPOT_TESTNET_URL=TESTNET_API_URL
BINANCE_SPOT_MAINNET_URL=MAINNET_API_URL
BINANCE_SPOT_FALLBACK_URLS=

# === Machine Learning ===
# Default in code: ML_ENABLED=true (set false for CI/dev without TensorFlow/model files)
ML_ENABLED=true
# Parent dir of per-symbol folders named exactly SYMBOL_TIMEFRAME (e.g. models/BTCUSDT_5m). Or set to that folder for one pair.
ML_MODEL_DIR=models
ML_LOOKBACK=50
ML_AGREE_THRESHOLD=0.70
# ML can override directional rules when softmax confidence >= this (default 0.60)
ML_OVERRIDE_THRESHOLD=0.60
# Strong ML path — always follow ML when confidence >= this (default 0.70)
ML_PRIORITIZE_THRESHOLD=0.70
# If true and model files missing at startup, start background training (long-running)
# ML_AUTO_TRAIN_ON_START=false
# When true: missing model / load fail / inference fail aborts the cycle (no silent rule-only)
ML_STRICT=true
# If rules say HOLD but ML predicts BUY/SELL with confidence >= this, follow ML (stronger AI path)
ML_HOLD_BREAKOUT_ENABLED=true
ML_HOLD_BREAKOUT_MIN_CONFIDENCE=0.52
# Min softmax to execute ML-driven BUY (default 0.55); never below ML_ABSOLUTE_MIN_CONFIDENCE
ML_MIN_TRADE_CONFIDENCE=0.55
ML_ABSOLUTE_MIN_CONFIDENCE=0.50
# Block BUY when any entry gate fails (trend/momentum/volatility/ml/risk)
STRICT_ENTRY_GATES=false
# AES-256-GCM: set to encrypt api_secret stored via PUT /auth/exchange-config (requires: pip install cryptography)
# SECRETS_ENCRYPTION_KEY=your-long-random-secret-string

# ================================
# ADAPTIVE TRADING STRATEGY CONFIG
# ================================

# === General Trading Parameters ===
TRADE_SYMBOL=BTCUSDT
TRADE_TIMEFRAME=5m
TRADE_LOOKBACK=500
# Multi-coin scheduler: comma-separated pairs or Binance symbols (default BTC, ETH, SOL)
# SUPPORTED_TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
# RL portfolio (optional — pip install -r requirements-rl.txt, train scripts/train_ppo_portfolio.py)
# RL_HYBRID_ENABLED=false
# RL_PPO_MODEL_PATH=models/ppo_portfolio.zip
# RL_MAX_WEIGHT_PER_ASSET=0.40
# PORTFOLIO_REBALANCE_CYCLES=20
# PORTFOLIO_MAX_DRAWDOWN_PCT=0.15
# PORTFOLIO_LOSS_REDUCE_FACTOR=0.65

# === Regime Detection Parameters ===
# ADX >= 25 = Trending, ADX < 25 = Ranging
ADX_THRESHOLD=25.0
ATR_VOL_THRESHOLD=2.0

# === Trending Market Rules ===
EMA_FAST=20
EMA_SLOW=50
RSI_LEN=14
RSI_BUY_MIN=45.0
RSI_BUY_MAX=70.0
RSI_TAKE_PROFIT=75.0

# === Ranging Market Rules ===
BB_LEN=20
BB_STD=2.0
RSI_RANGE_BUY=35.0
RSI_RANGE_SELL=65.0

# === Risk Management ===
MAX_RISK_PER_TRADE=0.01
STOP_LOSS_ATR_MULT=2.0
TAKE_PROFIT_RR=2.0
MAX_OPEN_TRADES=1
COOLDOWN_SECONDS=60

# === Order Execution Mode ===
DEMO_OPEN_ONLY=false
DEMO_FILL_MODE=true

# === Scheduler (live auto-trade) ===
LIVE_SCHEDULER_ENABLED=false
# Interval in minutes; increase to 10–15 if jobs often run long (avoids "previous run still in progress")
SCHEDULER_INTERVAL_MINUTES=5

# === Testing only: relax entry to get more BUY/SELL signals (use on testnet only) ===
RELAXED_ENTRY_FOR_TESTING=false

# === VPS / production dashboard (CORS + startup-check) ===
# Comma-separated browser origins (extra; http://147.93.96.42 is also allowed in code by default).
# Example: CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# CORS_ORIGINS=

# Optional: full URL of deployed dashboard — used by GET /status/startup-check to ping UI
# DASHBOARD_URL=https://app.yourdomain.com
