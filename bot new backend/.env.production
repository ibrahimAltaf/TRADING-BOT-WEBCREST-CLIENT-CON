# Copy to server as .env or merge with your secrets
APP_ENV=production
DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/trading
ML_ENABLED=true
ML_STRICT=true
ML_MODEL_DIR=models/btc_usdt_5m
ML_LOOKBACK=50
ML_OVERRIDE_THRESHOLD=0.60
ML_PRIORITIZE_THRESHOLD=0.70
ML_HOLD_BREAKOUT_MIN_CONFIDENCE=0.52
ML_MIN_TRADE_CONFIDENCE=0.55
ML_ABSOLUTE_MIN_CONFIDENCE=0.50
TRADE_SYMBOL=BTCUSDT
TRADE_TIMEFRAME=5m
BINANCE_TESTNET=false
LIVE_SCHEDULER_ENABLED=true
JWT_SECRET=change-me-strong-secret
